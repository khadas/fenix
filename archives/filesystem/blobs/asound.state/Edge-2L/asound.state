state.rockchipes8316c {
	control.1 {
		iface MIXER
		name 'SAI2 Transmit Start Mode Sel'
		value Standalone
		comment {
			access 'read write'
			type ENUMERATED
			count 1
			item.0 Standalone
			item.1 Chained
		}
	}
	control.2 {
		iface MIXER
		name 'SAI2 Receive Start Mode Sel'
		value Standalone
		comment {
			access 'read write'
			type ENUMERATED
			count 1
			item.0 Standalone
			item.1 Chained
		}
	}
	control.3 {
		iface MIXER
		name 'SAI2 Transmit SDOx Select'
		value Auto
		comment {
			access 'read write'
			type ENUMERATED
			count 1
			item.0 Auto
			item.1 SDOx1
			item.2 SDOx2
			item.3 SDOx3
			item.4 SDOx4
		}
	}
	control.4 {
		iface MIXER
		name 'SAI2 Receive SDIx Select'
		value Auto
		comment {
			access 'read write'
			type ENUMERATED
			count 1
			item.0 Auto
			item.1 SDIx1
			item.2 SDIx2
			item.3 SDIx3
			item.4 SDIx4
		}
	}
	control.5 {
		iface MIXER
		name 'SAI2 Receive Mono Slot Select'
		value 0
		comment {
			access 'read write'
			type INTEGER
			count 1
			range '0 - 128'
			dbmin 0
			dbmax 16384
			dbvalue.0 0
		}
	}
	control.6 {
